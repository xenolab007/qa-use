# https://cloud.browser-use.com/billing
BROWSER_USE_API_KEY=""

# Create once via: POST https://api.browser-use.com/api/v1/workspaces
# Enables script caching — repeat test runs cost ~$0 LLM after first run
BROWSER_USE_WORKSPACE_ID=""

# Persistent Browser Use profile ID — stores auth state (localStorage, cookies) so
# login steps never appear as AI-evaluated steps in test runs.
# Setup: create a profile at cloud.browser-use.com, then call
#   POST /api/browser-use/refresh-profile  (seeds the profile using BROWSER_SETUP_STEPS)
# Refresh whenever auth tokens expire.
BROWSER_USE_PROFILE_ID=""

# JSON array of AI steps injected before every test — only used when
# BROWSER_USE_PROFILE_ID is NOT set (fallback / non-auth steps).
# Supports {{TEST_AUTH_SECRET}} placeholder.
BROWSER_SETUP_STEPS=""

# Secret passed to your app's test-auth endpoint via {{TEST_AUTH_SECRET}} placeholder
TEST_AUTH_SECRET=""

# JWT for the test account (userId 4032, merchantId 120).
# How to get: log in to ai.xeno.in → DevTools → Application → Local Storage → user → tokenId
# Update this when the token expires, then call POST /api/browser-use/refresh-profile again.
TEST_AUTH_TOKEN=""

# https://app.inngest.com — Event Keys
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# https://resend.com/
RESEND_API_KEY=""

# NOTE: You can use `onboarding@resend.dev`` to send email to your account in the testing phase.
#       We recommend you verify your domain when rolling out QA Use internally.
RESEND_FROM_EMAIL="Example <onboarding@resend.dev>"